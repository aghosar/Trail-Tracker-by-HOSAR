{
  "expo": {
    "name": "Trail Tracker by HOSAR",
    "slug": "trail-tracker-by-hosar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/new logo.jpeg",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/new logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#10B981"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hosar.trailtracker",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Trail Tracker needs your location to track your outdoor activities and send your position to emergency contacts for safety.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Trail Tracker needs continuous location access to track your outdoor activities and send periodic updates to your emergency contacts for safety.",
        "NSLocationAlwaysUsageDescription": "Trail Tracker needs continuous location access to track your outdoor activities and send periodic updates to your emergency contacts for safety.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/new logo.jpeg",
        "backgroundColor": "#10B981"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.hosar.trailtracker",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Trail Tracker needs your location to track your outdoor activities and send updates to emergency contacts for safety.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "scheme": "trailtrackerbyhosar",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "backendUrl": "https://6dy99envtjn2qyu6dycuzm36mk4wv85a.app.specular.dev"
    }
  }
}